        {
          "slot": "mid",
          "label": "Speed",
          "lcd_label": "Spee",
          "active": true,
          "description": "Modulation speed."
        },
        {
          "slot": "right",
          "label": "Age",
          "lcd_label": "Age-",
          "active": true,
          "description": "Record wear macro control."
